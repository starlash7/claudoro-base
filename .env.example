# Public app URL without trailing slash
NEXT_PUBLIC_URL=https://claudoro-base.vercel.app

# Miniapp display text
NEXT_PUBLIC_MINIAPP_NAME=Claudoro
NEXT_PUBLIC_MINIAPP_SUBTITLE=Vibe coding focus timer
NEXT_PUBLIC_MINIAPP_DESCRIPTION=Run focused coding sessions with Pomodoro, streak tracking, and optional GitHub context.
NEXT_PUBLIC_MINIAPP_TAGLINE=Ship in focused sprints
NEXT_PUBLIC_MINIAPP_CATEGORY=productivity
NEXT_PUBLIC_MINIAPP_TAGS=focus,timer,pomodoro
NEXT_PUBLIC_MINIAPP_BUTTON_TITLE=Start Focus
NEXT_PUBLIC_MINIAPP_SPLASH_BG=#0B0F1A
NEXT_PUBLIC_MINIAPP_SCREENSHOTS=https://claudoro-base.vercel.app/screenshot-1.png,https://claudoro-base.vercel.app/screenshot-2.png,https://claudoro-base.vercel.app/screenshot-3.png

# Signed account association from Base Build / Farcaster tooling
MINIAPP_ACCOUNT_ASSOCIATION_HEADER=REPLACE_WITH_HEADER
MINIAPP_ACCOUNT_ASSOCIATION_PAYLOAD=REPLACE_WITH_PAYLOAD
MINIAPP_ACCOUNT_ASSOCIATION_SIGNATURE=REPLACE_WITH_SIGNATURE
